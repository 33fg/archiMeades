# Gravitational Platform - Backend Environment
# Copy to .env and fill in values

# Database (use asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gravitational

# Redis (for Celery, rate limiting - Phase 3)
REDIS_URL=redis://localhost:6379/0

# AWS
AWS_REGION=us-east-1
S3_BUCKET=gravitational-simulations
# LocalStack (local S3): run `npm run s3:start` then uncomment:
# AWS_ENDPOINT_URL=http://localhost:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test

# Cognito (Phase 2 - JWT auth)
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_JWKS_URL=

# Neo4j (provenance - WO-3, WO-20)
# Archimedes uses 7688 (Bolt) to avoid conflict with ResearchPlatform (7689) and carver (7687)
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=gravitational

# DGX GPU cluster - health, rate limit fallback when at capacity
DGX_HOST=10.88.111.9
# DGX_BASE_URL=http://10.88.111.9:8000  # optional; default http://{DGX_HOST}:8000
# DGX_HEALTH_PATH=/health
# DGX_TIMEOUT=5.0
# DGX_ENABLED=true  # set false to skip DGX checks
# DGX_CELERY_QUEUE=dgx  # route GPU tasks to DGX workers; empty = default queue

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Logging
LOG_LEVEL=INFO
DEBUG=false
